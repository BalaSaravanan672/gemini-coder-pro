{
  "name": "gemini-coder-monorepo",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@gemini-coder/cli",
    "dev:server": "npm run dev:server --workspace=@gemini-coder/cli",
    "start": "npm run start --workspace=@gemini-coder/cli",
    "serve": "npm run serve --workspace=@gemini-coder/cli",
    "test": "vitest run",
    "lint": "eslint packages/*/src",
    "format": "prettier --write packages/*/src"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
